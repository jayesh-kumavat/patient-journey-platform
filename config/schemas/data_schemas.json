{
  "prescriptions": {
    "type": "object",
    "required": ["prescription_id", "patient_id", "physician_id", "drug_name", "prescription_date", "quantity"],
    "properties": {
      "prescription_id": {"type": "string"},
      "patient_id": {"type": "string"},
      "physician_id": {"type": "string"},
      "drug_name": {"type": "string"},
      "prescription_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
      "quantity": {"type": "integer", "minimum": 1},
      "refills": {"type": "integer", "minimum": 0},
      "therapy_area": {"type": "string"}
    }
  },
  "diagnoses": {
    "type": "object",
    "required": ["diagnosis_id", "patient_id", "icd_code", "diagnosis_date"],
    "properties": {
      "diagnosis_id": {"type": "string"},
      "patient_id": {"type": "string"},
      "icd_code": {"type": "string"},
      "diagnosis_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
      "physician_id": {"type": "string"},
      "severity": {"type": "string", "enum": ["mild", "moderate", "severe"]}
    }
  },
  "claims": {
    "type": "object",
    "required": ["claim_id", "patient_id", "claim_date", "amount"],
    "properties": {
      "claim_id": {"type": "string"},
      "patient_id": {"type": "string"},
      "claim_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
      "amount": {"type": "number", "minimum": 0},
      "status": {"type": "string", "enum": ["approved", "denied", "pending"]},
      "payer": {"type": "string"}
    }
  },
  "patients": {
    "type": "object",
    "required": ["patient_id", "gender", "date_of_birth", "region"],
    "properties": {
      "patient_id": {"type": "string"},
      "gender": {"type": "string", "enum": ["M", "F", "Other"]},
      "date_of_birth": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
      "region": {"type": "string"},
      "enrollment_date": {"type": "string"}
    }
  },
  "physicians": {
    "type": "object",
    "required": ["physician_id", "specialty", "region"],
    "properties": {
      "physician_id": {"type": "string"},
      "specialty": {"type": "string"},
      "region": {"type": "string"},
      "years_experience": {"type": "integer", "minimum": 0}
    }
  }
}
